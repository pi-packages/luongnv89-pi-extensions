{
  "name": "grok-pi",
  "version": "1.0.0",
  "description": "Bridge Grok CLI session models (Composer 2.5, Grok Build) into Pi via cli-chat-proxy",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "pi": {
