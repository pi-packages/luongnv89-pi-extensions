    "type": "git",
    "url": "git+https://github.com/luongnv89/pi-extensions.git"
  },
  "bugs": {
    "url": "https://github.com/luongnv89/pi-extensions/issues"
  },
  "homepage": "https://github.com/luongnv89/pi-extensions/tree/main/extensions/grok-pi",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.4"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}