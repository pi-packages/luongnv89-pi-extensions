{
  "name": "opencode-pi",
  "version": "1.1.1",
  "description": "Bridge OpenCode CLI free models into Pi without OpenCode login",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/luongnv89/pi-extensions/main/assets/opencode-pi.png"
  },
  "keywords": [
    "pi-package",
    "pi",
    "opencode",
    "free-models",
    "custom-provider"
  ],
  "author": "pi-extensions contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luongnv89/pi-extensions.git"
  },
  "bugs": {
    "url": "https://github.com/luongnv89/pi-extensions/issues"
  },
  "homepage": "https://github.com/luongnv89/pi-extensions/tree/main/extensions/opencode-pi",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@earendil-works/pi-ai": "^0.75.4"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
